{
  "manifest_version": 3,
  "name": "SaraçApp Sipariş Entegrasyonu",
  "version": "1.0",
  "description": "Yemeksepeti ve Trendyol Yemek portallarını dinleyerek yeni siparişleri yerel POS sistemine aktarır.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://partner-app.yemeksepeti.com/*",
        "*://partner.tgoyemek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
